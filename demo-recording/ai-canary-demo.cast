[4.602786, "o", "\r\nOne orchestrator, three specialists (logs, metrics, events), plus a\r\nlog-proxy that gives the sandboxed log agent safe, policy-compliant\r\naccess to real pod logs. They debate every canary and vote.\r\n"]
